{
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "target": "esnext",
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "erasableSyntaxOnly": true,
    "verbatimModuleSyntax": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": false
  },
  "include": [
    "browser/**/*.ts",
    "browser/**/*.tsx",
    "components/**/*.ts",
    "components/**/*.tsx",
    "domain/**/*.ts",
    "server/**/*.ts",
    "test/browser/**/*.ts",
    "test/hosted/**/*.ts",
    "test/playback-domain.test.ts",
    "test/types/browser-*.type-test.ts",
    "test/types/playback-domain.type-test.ts",
    "scripts/**/*.ts"
  ],
  "exclude": ["dist", "node_modules"]
}
