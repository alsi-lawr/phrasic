#!/bin/sh
set -eu

staged_files="$(mktemp "${TMPDIR:-/tmp}/obs-nowplaying-staged.XXXXXX")"
format_files="$(mktemp "${TMPDIR:-/tmp}/obs-nowplaying-format.XXXXXX")"
formatted_files="$(mktemp "${TMPDIR:-/tmp}/obs-nowplaying-formatted.XXXXXX")"
trap 'rm -f -- "$staged_files" "$format_files" "$formatted_files"' 0 HUP INT TERM

git diff --cached --name-only -z >"$staged_files"

if [ ! -s "$staged_files" ]; then
    exit 0
fi

git diff --cached --name-only -z --diff-filter=ACMR >"$format_files"

if [ ! -s "$format_files" ]; then
    exit 0
fi

prettier_entrypoint="$(git rev-parse --show-toplevel)/node_modules/prettier/bin/prettier.cjs"

if [ ! -f "$prettier_entrypoint" ]; then
    printf '%s\n' 'pre-commit: local Prettier is unavailable; run bun ci --frozen-lockfile --omit peer before committing.' >&2
    exit 1
fi

xargs -0 bun "$prettier_entrypoint" --write --ignore-unknown -- <"$format_files"
xargs -0 git diff --name-only -z -- <"$format_files" >"$formatted_files"

if [ ! -s "$formatted_files" ]; then
    exit 0
fi

xargs -0 git add -- <"$formatted_files"
