#!/bin/sh
set -eu

staged_files="$(mktemp "${TMPDIR:-/tmp}/obs-nowplaying-staged.XXXXXX")"
format_files="$(mktemp "${TMPDIR:-/tmp}/obs-nowplaying-format.XXXXXX")"
trap 'rm -f -- "$staged_files" "$format_files"' 0 HUP INT TERM

git diff --cached --name-only -z > "$staged_files"

if [ ! -s "$staged_files" ]; then
  exit 0
fi

if ! xargs -0 git diff --quiet -- < "$staged_files"; then
  printf '%s\n' 'pre-commit: staged files also have unstaged changes; commit whole files or unstage them before committing.' >&2
  exit 1
fi

git diff --cached --name-only -z --diff-filter=ACMR > "$format_files"

if [ ! -s "$format_files" ]; then
  exit 0
fi

xargs -0 npm exec -- prettier --write --ignore-unknown -- < "$format_files"
xargs -0 git add -- < "$format_files"
