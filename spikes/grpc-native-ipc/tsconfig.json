{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "exactOptionalPropertyTypes": true,
    "forceConsistentCasingInFileNames": true,
    "lib": ["DOM", "ES2024"],
    "module": "Preserve",
    "moduleDetection": "force",
    "moduleResolution": "bundler",
    "noEmit": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noUncheckedIndexedAccess": true,
    "strict": true,
    "target": "ES2024",
    "types": ["bun-types"]
  },
  "include": [
    "browser/**/*.ts",
    "generated/**/*.d.ts",
    "scripts/**/*.ts",
    "terminator/**/*.ts",
    "test/**/*.ts"
  ]
}
