{
  "name": "spotify-nowplaying",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=26 <27",
    "npm": ">=12 <13"
  },
  "scripts": {
    "dev": "vite",
    "clean": "rm -rf dist",
    "build": "vite build",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --project tsconfig.json",
    "typecheck:browser": "tsc --project tsconfig.browser.json",
    "test": "node --loader ./test/tsx-loader.mjs --test \"test/**/*.test.ts\"",
    "prepare": "husky",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "prettier": "^3.9.5",
    "tailwindcss": "^4.3.2",
    "typescript": ">=5.9.3 <7.1.0",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.4"
  }
}
